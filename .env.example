# TBE Environment — copy to .env and fill in real values
# NEVER commit .env to git
#
# Keys below use the .NET IConfiguration env-var delimiter (double underscore → colon nesting).
# The top block keeps the legacy docker-compose placeholders; the 03-03 block below adds
# COMP-05 required secrets so every service Program.cs can boot from env alone.

# MSSQL
MSSQL_SA_USER=sa
MSSQL_SA_PASSWORD=P@kistan31312

# Per-service connection strings (point to same MSSQL host, different databases)
BOOKING_DB_CONNECTION=Server=194.35.120.124,54321;Database=BookingDb;User Id=sa;Password=P@kistan31312;TrustServerCertificate=True;
PAYMENT_DB_CONNECTION=Server=194.35.120.124,54321;Database=PaymentDb;User Id=sa;Password=P@kistan31312;TrustServerCertificate=True;
SEARCH_DB_CONNECTION=Server=194.35.120.124,54321;Database=SearchDb;User Id=sa;Password=P@kistan31312;TrustServerCertificate=True;
PRICING_DB_CONNECTION=Server=194.35.120.124,54321;Database=PricingDb;User Id=sa;Password=P@kistan31312;TrustServerCertificate=True;
NOTIFICATION_DB_CONNECTION=Server=194.35.120.124,54321;Database=NotificationDb;User Id=sa;Password=P@kistan31312;TrustServerCertificate=True;
CRM_DB_CONNECTION=Server=194.35.120.124,54321;Database=CrmDb;User Id=sa;Password=P@kistan31312;TrustServerCertificate=True;
BACKOFFICE_DB_CONNECTION=Server=194.35.120.124,54321;Database=BackofficeDb;User Id=sa;Password=P@kistan31312;TrustServerCertificate=True;
FLIGHT_CONNECTOR_DB_CONNECTION=Server=194.35.120.124,54321;Database=FlightConnectorDb;User Id=sa;Password=P@kistan31312;TrustServerCertificate=True;
HOTEL_CONNECTOR_DB_CONNECTION=Server=194.35.120.124,54321;Database=HotelConnectorDb;User Id=sa;Password=P@kistan31312;TrustServerCertificate=True;

# RabbitMQ
RABBITMQ_USER=tbe_admin
RABBITMQ_PASSWORD=P@kistan31312

# Redis
REDIS_PASSWORD=P@kistan31312

# Keycloak
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=P@kistan31312

# Keycloak realm client secrets (injected into realm JSON via KC env substitution)
TBE_B2C_GATEWAY_CLIENT_SECRET=your-b2c-gateway-secret-here
TBE_B2B_GATEWAY_CLIENT_SECRET=your-b2b-gateway-secret-here
TBE_BACKOFFICE_GATEWAY_CLIENT_SECRET=your-backoffice-gateway-secret-here

# GDS API keys (Phase 2 — leave blank for Phase 1)
AMADEUS_API_KEY=
AMADEUS_API_SECRET=

# ============================================================
# 03-03 additions (COMP-05): IConfiguration-style secrets.
# These override appsettings.*.json values at runtime. Keep these empty in .env.example;
# fill only your local .env (gitignored).
# ============================================================

# ---- Database connection strings (IConfiguration style) ----
CONNECTIONSTRINGS__BOOKINGDB=
CONNECTIONSTRINGS__PAYMENTDB=
CONNECTIONSTRINGS__NOTIFICATIONDB=
CONNECTIONSTRINGS__PRICINGDB=

# ---- Messaging / cache (IConfiguration style) ----
RABBITMQ__HOST=localhost
RABBITMQ__USERNAME=tbe
RABBITMQ__PASSWORD=
REDIS__CONNECTIONSTRING=localhost:6379

# ---- Identity (Keycloak OIDC) ----
KEYCLOAK__AUTHORITY=http://localhost:8080/realms/tbe-b2c
KEYCLOAK__AUDIENCE=tbe-b2c-api

# ---- AES-256 field encryption. Generate: openssl rand -base64 32 ----
ENCRYPTION__ACTIVEKEYBASE64=
ENCRYPTION__ACTIVEKEYVERSION=1

# ---- Stripe (PaymentService) ----
STRIPE__APIKEY=
STRIPE__PUBLISHABLEKEY=
STRIPE__WEBHOOKSECRET=

# ---- SendGrid (NotificationService) ----
SENDGRID__APIKEY=

# ---- GDS credentials (FlightConnectorService) ----
AMADEUS__APIKEY=
AMADEUS__APISECRET=
SABRE__USERNAME=
SABRE__PASSWORD=
SABRE__PCC=
GALILEO__USERNAME=
GALILEO__PASSWORD=

# ---- Third-party aggregators ----
HOTELBEDS__APIKEY=
HOTELBEDS__APISECRET=

# ---- OpenTelemetry ----
OPENTELEMETRY__OTLPENDPOINT=http://localhost:4317
