# TBE Environment — copy to .env and fill in real values
# NEVER commit .env to git
#
# Keys below use the .NET IConfiguration env-var delimiter (double underscore = colon nesting).
# The top block keeps the legacy docker-compose placeholders; the second block carries the
# COMP-05 runtime secrets so every service Program.cs can boot from env alone.
# The third block (added by quick-260424-20h) centralises Keycloak + Gateway public URLs.

# Runtime / dotnet
ASPNETCORE_ENVIRONMENT=Development

# MSSQL
MSSQL_SA_USER=sa
MSSQL_SA_PASSWORD=P@kistan31232

# Per-service connection strings (point to same MSSQL host, different databases)
BOOKING_DB_CONNECTION=Server=mssql;Database=BookingDb;User Id=sa;Password=P@kistan31232;TrustServerCertificate=True;
PAYMENT_DB_CONNECTION=Server=mssql;Database=PaymentDb;User Id=sa;Password=P@kistan31232;TrustServerCertificate=True;
SEARCH_DB_CONNECTION=Server=mssql;Database=SearchDb;User Id=sa;Password=P@kistan31232;TrustServerCertificate=True;
PRICING_DB_CONNECTION=Server=mssql;Database=PricingDb;User Id=sa;Password=P@kistan31232;TrustServerCertificate=True;
NOTIFICATION_DB_CONNECTION=Server=mssql;Database=NotificationDb;User Id=sa;Password=P@kistan31232;TrustServerCertificate=True;
CRM_DB_CONNECTION=Server=mssql;Database=CrmDb;User Id=sa;Password=P@kistan31232;TrustServerCertificate=True;
BACKOFFICE_DB_CONNECTION=Server=mssql;Database=BackofficeDb;User Id=sa;Password=P@kistan31232;TrustServerCertificate=True;
FLIGHT_CONNECTOR_DB_CONNECTION=Server=mssql;Database=FlightConnectorDb;User Id=sa;Password=P@kistan31232;TrustServerCertificate=True;
HOTEL_CONNECTOR_DB_CONNECTION=Server=mssql;Database=HotelConnectorDb;User Id=sa;Password=P@kistan31232;TrustServerCertificate=True;

# RabbitMQ
RABBITMQ_USER=tbe_admin
RABBITMQ_PASSWORD=P@kistan31232

# Redis
REDIS_PASSWORD=P@kistan31232

# Keycloak (local admin — unused when external Keycloak at openid.3ha.one is used)
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=P@kistan31232

# Keycloak realm client secrets (injected into realm JSON via KC env substitution)
TBE_B2C_GATEWAY_CLIENT_SECRET=
TBE_B2B_GATEWAY_CLIENT_SECRET=
TBE_BACKOFFICE_GATEWAY_CLIENT_SECRET=

# Backoffice portal Auth.js
KEYCLOAK_BACKOFFICE_CLIENT_SECRET=replace-me
KEYCLOAK_BACKOFFICE_ADMIN_CLIENT_SECRET=replace-me
KEYCLOAK_B2B_ADMIN_CLIENT_SECRET=
NEXTAUTH_SECRET=replace-me-with-32-char-random-string

# GDS API keys (Phase 2 — leave blank for Phase 1)
AMADEUS_API_KEY=
AMADEUS_API_SECRET=

# ============================================================
# 03-03 additions (COMP-05): IConfiguration-style secrets.
# These override appsettings.*.json values at runtime. Keep these empty in .env.example;
# fill only your local .env (gitignored).
# ============================================================

# ---- Database connection strings (IConfiguration style) ----
CONNECTIONSTRINGS__BOOKINGDB=
CONNECTIONSTRINGS__PAYMENTDB=
CONNECTIONSTRINGS__NOTIFICATIONDB=
CONNECTIONSTRINGS__PRICINGDB=

# ---- Messaging / cache (IConfiguration style) ----
RABBITMQ__HOST=rabbitmq
RABBITMQ__USERNAME=tbe_admin
RABBITMQ__PASSWORD=
REDIS__CONNECTIONSTRING=redis:6378

# ---- Identity (Keycloak OIDC — external) ----
KEYCLOAK__AUTHORITY=https://openid.3ha.one/realms/tbe-b2c
KEYCLOAK__AUDIENCE=tbe-b2c-api
KEYCLOAK__BASEURL=https://openid.3ha.one

# KeycloakB2B client secrets (PaymentService + BookingService service-accounts for tbe-b2b realm)
KEYCLOAKB2B__CLIENTSECRET=
KEYCLOAKB2B__BOOKING__CLIENTSECRET=

# ---- AES-256 field encryption. Generate: openssl rand -base64 32 ----
ENCRYPTION__ACTIVEKEYBASE64=
ENCRYPTION__ACTIVEKEYVERSION=1

# ---- Stripe (PaymentService) ----
STRIPE__APIKEY=
STRIPE__PUBLISHABLEKEY=
STRIPE__WEBHOOKSECRET=

# ---- Wallet (PaymentService) ----
WALLET__TOPUP__MINAMOUNT=10
WALLET__TOPUP__MAXAMOUNT=50000
WALLET__LOWBALANCE__DEFAULTTHRESHOLD=500
WALLET__LOWBALANCE__EMAILCOOLDOWNHOURS=24
WALLET__LOWBALANCE__POLLINTERVALMINUTES=15

# ---- SendGrid (NotificationService) ----
SENDGRID__APIKEY=
SENDGRID__FROMEMAIL=no-reply@tbe.travel
SENDGRID__FROMNAME=TBE Bookings
SENDGRID__SANDBOXMODE=false

# ---- GDS credentials (FlightConnectorService) ----
AMADEUS__APIKEY=
AMADEUS__APISECRET=
SABRE__USERNAME=
SABRE__PASSWORD=
SABRE__PCC=
GALILEO__USERNAME=
GALILEO__PASSWORD=

# ---- Third-party aggregators (HotelConnectorService) ----
HOTELBEDS__APIKEY=
HOTELBEDS__APISECRET=

# ---- OpenTelemetry ----
OPENTELEMETRY__OTLPENDPOINT=http://localhost:4317

# ============================================================
# 260424-20h additions: Keycloak + Gateway public URLs
# External Keycloak at openid.3ha.one, gateway fronted at booking.3ha.one.
# Services should prefer these over per-service Keycloak:BaseUrl defaults.
# ============================================================

KEYCLOAK_PUBLIC_URL=https://openid.3ha.one
GATEWAY_PUBLIC_URL=https://booking.3ha.one
