{
  "realm": "tbe-b2c",
  "enabled": true,
  "sslRequired": "external",
  "registrationAllowed": true,
  "loginWithEmailAllowed": true,
  "accessTokenLifespan": 300,
  "clients": [
    {
      "clientId": "tbe-web",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "redirectUris": ["http://localhost:3000/*", "https://booking.3ha.one/*", "https://*.3ha.one/*"],
      "webOrigins": ["http://localhost:3000", "https://booking.3ha.one", "https://*.3ha.one"],
      "protocol": "openid-connect"
    },
    {
      "clientId": "tbe-gateway",
      "enabled": true,
      "publicClient": false,
      "serviceAccountsEnabled": true,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "secret": "${TBE_B2C_GATEWAY_CLIENT_SECRET}",
      "protocol": "openid-connect"
    }
  ],
  "roles": {
    "realm": [
      { "name": "customer", "description": "B2C customer role" }
    ]
  }
}
