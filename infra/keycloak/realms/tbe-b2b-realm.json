{
  "realm": "tbe-b2b",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "accessTokenLifespan": 300,
  "clients": [
    {
      "clientId": "tbe-agent-portal",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "redirectUris": ["http://localhost:3001/*", "https://booking.3ha.one/*", "https://*.3ha.one/*"],
      "webOrigins": ["http://localhost:3001", "https://booking.3ha.one", "https://*.3ha.one"],
      "protocol": "openid-connect"
    },
    {
      "clientId": "tbe-gateway",
      "enabled": true,
      "publicClient": false,
      "serviceAccountsEnabled": true,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "secret": "${TBE_B2B_GATEWAY_CLIENT_SECRET}",
      "protocol": "openid-connect"
    }
  ],
  "roles": {
    "realm": [
      { "name": "agent-admin", "description": "Agency administrator" },
      { "name": "agent", "description": "Travel agent" },
      { "name": "agent-readonly", "description": "Read-only agent access" }
    ]
  }
}
