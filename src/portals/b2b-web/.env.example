# B2B Agent Portal environment (Phase 5 Plan 05-00).
#
# Never prefix secret values with NEXT_PUBLIC_*. Only the Stripe publishable
# key uses the NEXT_PUBLIC_ prefix so it can be embedded in the browser.

# --- Keycloak OIDC (D-22, D-23, D-32) -------------------------------------------
# The tbe-b2b realm is the auth target. See infra/keycloak/README.md for import
# steps. Different realm + client from the B2C portal on :3000.
KEYCLOAK_B2B_CLIENT_ID=tbe-agent-portal
KEYCLOAK_B2B_CLIENT_SECRET=replace-me-at-deploy
KEYCLOAK_B2B_ISSUER=http://localhost:8080/realms/tbe-b2b

# --- Keycloak admin client (Pitfall 8 / mitigation T-05-00-02) -----------------
# Dedicated service account with realm-management `manage-users` for the
# B2B-10 sub-agent create flow (Plan 05-01) and any future admin ops.
KEYCLOAK_B2B_ADMIN_CLIENT_ID=tbe-b2b-admin
KEYCLOAK_B2B_ADMIN_CLIENT_SECRET=replace-me-at-deploy

# --- Auth.js v5 cookie signing -------------------------------------------------
# Generate with `openssl rand -base64 32`.
NEXTAUTH_SECRET=replace-me-at-deploy
NEXTAUTH_URL=http://localhost:3001

# --- YARP gateway (Bearer forwarding via gatewayFetch) -------------------------
# Same gateway as the B2C portal — the B2B JWT audience check flips on at the
# gateway in Plan 05-01.
GATEWAY_BASE_URL=http://localhost:8080
GATEWAY_URL=http://localhost:5080

# --- Stripe (wallet top-up — Plan 05-03 / mitigation T-05-00-03) ---------------
# PK is the only public value. SK lives in PaymentService and never the browser.
# CSP in next.config.mjs allows Stripe.js ONLY on /admin/wallet/* — Pitfall 16.
NEXT_PUBLIC_STRIPE_PK=pk_test_replace_me

# --- Wallet low-balance threshold (Plan 05-03) ---------------------------------
# Wallet chip flips to warning colour when balance < threshold (in GBP).
WALLET_LOW_BALANCE_THRESHOLD=500
