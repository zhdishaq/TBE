# B2C portal environment (COMP-05 — secrets must never ship in the client bundle)
#
# Never prefix secret values with NEXT_PUBLIC_*. Only the Stripe publishable key
# uses the NEXT_PUBLIC_ prefix so it can be embedded in the browser.

# --- Keycloak OIDC (D-04, D-05) -------------------------------------------------
# The tbe-b2c realm is the auth target. See infra/keycloak/README.md.
KEYCLOAK_B2C_CLIENT_ID=tbe-b2c
KEYCLOAK_B2C_CLIENT_SECRET=replace-me-at-deploy
KEYCLOAK_B2C_ISSUER=http://localhost:8080/realms/tbe-b2c

# --- Keycloak admin client (Pitfall 8) ------------------------------------------
# Dedicated service account with manage-users role for resend-verification.
KEYCLOAK_B2C_ADMIN_CLIENT_ID=tbe-b2c-admin
KEYCLOAK_B2C_ADMIN_CLIENT_SECRET=replace-me-at-deploy

# --- Auth.js v5 cookie signing (D-05) -------------------------------------------
# Generate with `openssl rand -base64 32`.
NEXTAUTH_SECRET=replace-me-at-deploy
NEXTAUTH_URL=http://localhost:3000

# --- YARP gateway (D-05 Bearer forwarding) --------------------------------------
GATEWAY_URL=http://localhost:5080

# --- Stripe (COMP-01 / Pitfall 16) ----------------------------------------------
# PK is the only public value. SK lives in PaymentService and never the browser.
NEXT_PUBLIC_STRIPE_PK=pk_test_replace_me
